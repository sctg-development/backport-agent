{
  "name": "@sctg/backport-agent",
  "version": "0.1.0",
  "description": "Generic fork sync & preservation agent powered by @sctg/cline-sdk",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "dry-run": "DRY_RUN=true tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --outDir dist",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@sctg/cline-sdk": "3.85.0-beta.20260526150719",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
