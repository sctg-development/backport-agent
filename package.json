{
  "name": "@sctg/backport-agent",
  "version": "0.8.1",
  "description": "Generic fork sync & preservation agent powered by @sctg/cline-sdk",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sctg-development/backport-agent.git"
  },
  "bin": {
    "backport-agent": "./dist/main.mjs"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE.md",
    "config.example.json",
    "customizations.example.yaml",
    "llm.md",
    "llm.txt"
  ],
  "scripts": {
    "start": "tsx src/main.ts",
    "dry-run": "DRY_RUN=true tsx src/main.ts",
    "dry-run:tea": "DRY_RUN=true BACKPORT_CUSTOMIZATIONS=/Users/rlemeill/Development/tea-ching-cline/.backport-agent/customizations.yaml tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@sctg/cline-sdk": "4.0.0-beta.20260724065706",
    "dotenv": "^17.4.2",
    "js-yaml": "^5.2.2",
    "minimatch": "^10.0.1",
    "tiktoken": "^1.0.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.0",
    "fast-glob": "^3.3.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "protobufjs@7.6.4": true
  }
}
