{
  "auth": {
    "_comment_ssh": "Use sshKeyPath for SSH remotes (supports ~ expansion)",
    "sshKeyPath": "~/.ssh/id_ed25519",
    "_comment_token": "Use githubToken for HTTPS remotes; prefix with $ to read from env var",
    "_githubToken_example": "$GITHUB_TOKEN"
  },
  "upstream": {
    "url": "git@github.com:cline/cline.git",
    "repo": "cline/cline",
    "branch": "dev",
    "remote": "upstream"
  },
  "fork": {
    "url": "git@github.com:TEA-ching/cline.git",
    "repo": "TEA-ching/cline",
    "branch": "keypool-live",
    "remote": "origin"
  },
  "workingDir": "/path/to/your/local/TEA-ching-cline-clone",
  "sync": {
    "maxCommitsPerRun": 20,
    "initialFetchDepth": 200,
    "maxFetchDepth": 4000,
    "batchSize": 5,
    "dryRun": true,
    "createPullRequest": true,
    "branchPrefix": "sync/upstream-"
  },
  "models": {
    "_comment_provider": "Any provider supported by @sctg/cline-sdk: \"keypoollive\", \"anthropic\", \"openai\", \"mistral\", \"gemini\", etc.",
    "provider": "keypoollive",
    "_comment_apiKey": "Use \"$ENV_VAR\" to read from env, \"auto\" for keypoollive vault, or omit to auto-detect {PROVIDER_UPPER}_API_KEY",
    "apiKey": "auto",
    "fast": "mistral/devstral-latest",
    "specialist": "mistral/devstral-latest",
    "powerful": "mistral/magistral-medium-latest"
  },
  "resolve": {
    "_comment": "Glob or /regex/flags patterns matched against repo-relative file paths",
    "ours": [
      "package-lock.json",
      "bun.lockb"
    ],
    "theirs": [
      "CHANGELOG.md",
      "/^docs\//"
    ]
  },
  "report": {
    "destination": "."
  },
  "validation": {
    "low": [
      "npm run typecheck"
    ],
    "medium": [
      "npm run typecheck",
      "npm run test:unit"
    ],
    "high": [
      "npm run typecheck",
      "npm run test:unit",
      "npm run compile"
    ]
  }
}
