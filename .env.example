# Backport Agent — Environment variables
# Copy this file to .env and fill in the values
# .env is in .gitignore: never commit secrets

# URL of the encrypted KeypoolLive vault (ai.json.XXX.enc)
# Example: https://raw.githubusercontent.com/sctg-development/ai-proxy-cloudflare/refs/heads/master/ai.sample.json.0123456789abcdef.enc
KEYPOOL_VAULT_URL=https://raw.githubusercontent.com/sctg-development/ai-proxy-cloudflare/refs/heads/master/ai.sample.json.0123456789abcdef.enc

# Decryption key for the vault (secret, never commit)
KEYPOOL_LIVE_SECRET=0123456789abcdef

# Path to the fork's customizations.yaml
# Points to the file in the local clone of TEA-ching/cline
BACKPORT_CUSTOMIZATIONS=./customizations.yaml

# Path to config.json (optional — default ./config.json in cwd)
BACKPORT_CONFIG=./config.json

# Path to the keypool state file (optional — default ./keypool-state.json in cwd)
KEYPOOL_STATE_FILE=./keypool-state.json

# Force dry-run mode (overrides config.json, useful in CI)
# DRY_RUN=true
